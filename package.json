{
  "name": "mdpdf-workspace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace web",
    "build:web": "npm run build --workspace web",
    "start:web": "npm run start --workspace web",
    "typecheck:web": "npm run typecheck --workspace web",
    "dev:pdf-api": "npm run dev --workspace pdf-api",
    "build:pdf-api": "npm run build --workspace pdf-api",
    "start:pdf-api": "npm run start --workspace pdf-api",
    "typecheck:pdf-api": "npm run typecheck --workspace pdf-api",
    "build": "npm run build:web && npm run build:pdf-api",
    "typecheck": "npm run typecheck:web && npm run typecheck:pdf-api"
  }
}